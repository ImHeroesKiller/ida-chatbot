# Gemini (required for chat, embeddings, OCR, STT fallback)
GEMINI_API_KEY=

# Tavily web search (optional — enables real-time web search in IDA chat)
# https://tavily.com
TAVILY_API_KEY=

# Groq (recommended for STT — Whisper Large v3)
GROQ_API_KEY=

# Optional providers (admin model library)
XAI_API_KEY=
HUGGINGFACE_API_KEY=

# OpenAI (optional — admin TTS engine)
OPENAI_API_KEY=

# Admin panel (/admin)
ADMIN_PASSWORD=

# Supabase server (required for RAG + session persistence)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase browser (REQUIRED for Google OAuth login)
# Project URL only — e.g. https://abcdefgh.supabase.co (NOT .../rest/v1)
# Anon/public key from Dashboard → Settings → API (NOT service_role)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Gmail ESL integration (optional — demo mode works without OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# ── AgentFlow AI (/agent) ──────────────────────────────────────────────
# E2B sandbox (optional — without key, execution runs in simulation mode)
# https://e2b.dev/docs/api-key
E2B_API_KEY=

# Redis checkpointer (optional — without Redis, workflow state uses memory)
# Option A: Upstash (recommended on Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Option B: Standard Redis URL
REDIS_URL=