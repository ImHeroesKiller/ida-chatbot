# Gemini (required for chat, embeddings, OCR, STT fallback)
GEMINI_API_KEY=

# Groq (recommended for STT — Whisper Large v3)
GROQ_API_KEY=

# Supabase server (required for RAG + session persistence)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase browser (optional — for client-side reads)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=